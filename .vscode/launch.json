{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Film/bin/Debug/net9.0/Film.dll",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build",
            "symbolSearchPath": "${workspaceFolder}/Film/bin/Debug/net9.0"
        }
    ]
}
